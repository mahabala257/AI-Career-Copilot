# Database (format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/career_copilot

# JWT secret (random 32+ chars). Generate in PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
JWT_SECRET_KEY=replace-with-a-random-32-character-string

# LLM (required) - get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional providers (leave blank if unused)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional LangFuse monitoring (leave blank if unused)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Application
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CHROMADB_PATH=./chroma_store
UPLOAD_DIR=./uploads
